{
  "manifest_version": 2,
  "name": "OpenBrowser",
  "version": "1.9.10",
  "description": "Local user-scoped browser control bridge for the OpenBrowser CLI.",
  "icons": {
    "48": "assets/logo.svg",
    "96": "assets/logo.svg",
    "128": "assets/logo.svg"
  },
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "openbrowser@mizius.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
