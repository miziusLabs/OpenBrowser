{
  "manifest_version": 3,
  "name": "OpenBrowser",
  "version": "2.1.0",
  "description": "Local user-scoped browser control bridge for the OpenBrowser CLI.",
  "key": "",
  "minimum_chrome_version": "109",
  "permissions": [
    "nativeMessaging",
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
